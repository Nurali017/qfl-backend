# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/qfl_db
WEB_STATEMENT_TIMEOUT_MS=30000

# SOTA API credentials
SOTA_API_EMAIL=kazachenko.galina@gmail.com
SOTA_API_PASSWORD=afd#@$afsad

# Legacy MySQL (one-time lineup backfill only)
LEGACY_MYSQL_HOST=localhost
LEGACY_MYSQL_PORT=3306
LEGACY_MYSQL_DB=p-348074_db
LEGACY_MYSQL_USER=p-348074_user
LEGACY_MYSQL_PASSWORD=
LEGACY_MYSQL_CONNECT_TIMEOUT_SECONDS=10
LEGACY_CURRENT_SEASON_ID=21

# Redis
REDIS_URL=redis://localhost:6379/0

# Current season (default for API when season_id not specified)
CURRENT_SEASON_ID=200

# Local season IDs to sync automatically via Celery
# KPL 2026 uses local season_id=200 and maps to SOTA via seasons.sota_season_id=173
SYNC_SEASON_IDS=[61,85,71,80,84,200,203,204]
# Seasons with SOTA v2 extended stats (excludes Вторая Лига)
EXTENDED_STATS_SEASON_IDS=[61,85,71,80,200,204]

# CORS
ALLOWED_ORIGINS=*

# Admin auth
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
ADMIN_ACCESS_TTL_MINUTES=30
ADMIN_REFRESH_TTL_DAYS=14
ADMIN_REFRESH_COOKIE_NAME=admin_refresh_token
ADMIN_COOKIE_SECURE=false
ADMIN_COOKIE_SAMESITE=lax
ADMIN_COOKIE_DOMAIN=
ADMIN_BOOTSTRAP_EMAIL=admin@qfl.local
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!

# Telegram notifications (admin ops chat)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=false

# Public Telegram posts (t.me/kffleague channel via Telethon user client)
# Every new TELEGRAM_*_ENABLED flag added to app/config.py MUST also be wired into
# docker-compose.prod.yml in all three services (qfl-backend, celery_worker,
# celery_live_worker); scripts/check_compose_env_parity.py enforces this on CI.
# Telegram-routed celery tasks (see app/tasks/__init__.py task_routes) are
# consumed by celery_worker via "-Q celery,telegram"; any new queue routed in
# task_routes needs a matching "-Q" flag — check_celery_queue_coverage.py
# enforces this.
TELEGRAM_PUBLIC_POSTS_ENABLED=false
TELEGRAM_PUBLIC_CHAT_ID=
TELEGRAM_TOUR_ANNOUNCE_ENABLED=false
TELEGRAM_MATCH_START_ENABLED=false

# Telethon user-session credentials (for sending to public channel)
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_PHONE=

# Weather (Open-Meteo, no API key needed)
WEATHER_ENABLED=false

# Serper (Google Search) API for ticket search
SERPER_API_KEY=
TICKET_SEARCH_ENABLED=false

# Frontend revalidation (on-demand ISR)
REVALIDATION_SECRET=
FRONTEND_INTERNAL_URL=http://qfl-frontend:3000

# Feature flags
CUP_DRAW_ENABLED=true

# Google Drive — goal video ingest
# Service account JSON path inside the container (mount from ./secrets/google-sa.json)
GOOGLE_DRIVE_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-sa.json
GOOGLE_DRIVE_GOALS_FOLDER_ID=
GOAL_VIDEO_AI_FALLBACK_ENABLED=true
GOAL_VIDEO_AI_MODEL=claude-haiku-4-5-20251001
GOAL_VIDEO_SYNC_INTERVAL_MINUTES=5
# Re-encode clips with ffmpeg before upload (≈40% smaller, visually identical).
GOAL_VIDEO_TRANSCODE_ENABLED=true
GOAL_VIDEO_TRANSCODE_CRF=20
GOAL_VIDEO_TRANSCODE_PRESET=medium
SOTA_DEAD_SEASON_MIN_404=30
SOTA_DEAD_SEASON_404_RATIO=0.8
SOTA_DEAD_SEASON_TTL_SECONDS=3600
DEBUG_SYNC_TIMINGS=false
