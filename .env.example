LEGACY_MYSQL_CONNECT_TIMEOUT_SECONDS=10
LEGACY_CURRENT_SEASON_ID=21

# Redis
REDIS_URL=redis://localhost:6379/0

# Current season (default for API when season_id not specified)
CURRENT_SEASON_ID=200

# Local season IDs to sync automatically via Celery
# KPL 2026 uses local season_id=200 and maps to SOTA via seasons.sota_season_id=173
SYNC_SEASON_IDS=[61,85,71,80,84,200,203,204]

# CORS
ALLOWED_ORIGINS=*

# Admin auth
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
ADMIN_ACCESS_TTL_MINUTES=30
ADMIN_REFRESH_TTL_DAYS=14
ADMIN_REFRESH_COOKIE_NAME=admin_refresh_token
ADMIN_COOKIE_SECURE=false
ADMIN_COOKIE_SAMESITE=lax
ADMIN_COOKIE_DOMAIN=
ADMIN_BOOTSTRAP_EMAIL=admin@qfl.local
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=false

# Weather (Open-Meteo, no API key needed)
WEATHER_ENABLED=false

# Serper (Google Search) API for ticket search
SERPER_API_KEY=
TICKET_SEARCH_ENABLED=false

# Frontend revalidation (on-demand ISR)
REVALIDATION_SECRET=
FRONTEND_INTERNAL_URL=http://qfl-frontend:3000

# Feature flags
CUP_DRAW_ENABLED=true
